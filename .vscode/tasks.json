{
  "version": "2.0.0",
  "tasks": [

    /* ================================
       BUILD (DEBUG)
       ================================ */
    {
      "label": "Build C++ (Debug)",
      "type": "shell",
      "command": "g++",
      "args": [
        "-std=c++17",
        "-g",
        "-Wall",
        "-Wextra",
        "${file}",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}"
      ],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": ["$gcc"]
    },

    /* ================================
       BUILD (RELEASE / CP)
       ================================ */
    {
      "label": "Build C++ (Release)",
      "type": "shell",
      "command": "g++",
      "args": [
        "-std=c++17",
        "-O2",
        "-Wall",
        "-Wextra",
        "${file}",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    },

    /* ================================
       RUN (BUILD + AUTO RUN)
       ================================ */
    {
      "label": "Run C++ (Build + Run)",
      "type": "shell",
      "command": "${fileDirname}/${fileBasenameNoExtension}",
      "dependsOn": "Build C++ (Release)",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },

    /* ================================
       CP RUN (INPUT → TERMINAL + output.txt)
       ================================ */
    {
      "label": "Run C++ CP (input.txt → terminal + output.txt)",
      "type": "shell",
      "command": "${fileDirname}/${fileBasenameNoExtension}",
      "dependsOn": "Build C++ (Release)",
      "args": [
        "<",
        "input.txt",
        "|",
        "tee",
        "output.txt"
      ],
      "options": {
        "shell": {
          "executable": "bash"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },

    /* ================================
       MULTI-FILE PROJECT BUILD
       ================================ */
    {
      "label": "Build C++ (Multi-file Project)",
      "type": "shell",
      "command": "g++",
      "args": [
        "-std=c++17",
        "-O2",
        "src/*.cpp",
        "-o",
        "app"
      ],
      "group": "build",
      "problemMatcher": ["$gcc"]
    },
{
  "label": "Run C++ CP (input.txt → terminal + output.txt)",
  "type": "shell",
  "command": "${fileDirname}/${fileBasenameNoExtension}",
  "dependsOn": "Build C++ (Release)",
  "args": [
    "<",
    "input.txt",
    "|",
    "tee",
    "output.txt"
  ],
  "options": {
    "shell": {
      "executable": "bash"
    }
  }
}
  ]
}